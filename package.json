{
  "name": "mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node scripts/expo-with-web-output.cjs start --web-output=single",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "node scripts/expo-with-web-output.cjs start --web --web-output=single",
    "secrets:scan": "node scripts/scan-secrets.mjs",
    "build:web": "node scripts/expo-with-web-output.cjs export --platform web --clear --web-output=static && node scripts/create-spa-redirects.js",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "assets:optimize": "node scripts/optimize-assets.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:ci": "jest --forceExit --detectOpenHandles --coverage --passWithNoTests --coverageThreshold='{\"global\":{\"branches\":80,\"functions\":80,\"lines\":80,\"statements\":80}}'",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage",
    "test:watch": "jest --watch",
    "analyze": "expo export --platform web --dump-sourcemap && source-map-explorer dist/_expo/static/js/web/*.js",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc-files --noEmit"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-sync-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "async-mutex": "^0.5.0",
    "axios": "^1.18.0",
    "axios-retry": "^4.5.0",
    "date-fns": "^4.4.0",
    "expo": "56.0.12",
    "expo-auth-session": "56.0.14",
    "expo-camera": "56.0.8",
    "expo-constants": "56.0.18",
    "expo-device": "56.0.4",
    "expo-document-picker": "56.0.4",
    "expo-file-system": "56.0.8",
    "expo-font": "56.0.7",
    "expo-haptics": "56.0.3",
    "expo-linear-gradient": "56.0.4",
    "expo-linking": "56.0.14",
    "expo-localization": "56.0.6",
    "expo-notifications": "56.0.18",
    "expo-router": "56.2.11",
    "expo-secure-store": "56.0.4",
    "expo-sharing": "56.0.18",
    "expo-splash-screen": "56.0.10",
    "expo-sqlite": "56.0.5",
    "expo-status-bar": "56.0.4",
    "expo-web-browser": "56.0.5",
    "i18next": "^26.0.5",
    "jspdf": "^4.2.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.79.0",
    "react-i18next": "^17.0.3",
    "react-native": "0.85.3",
    "react-native-calendars": "^1.1314.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-native/jest-preset": "0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "12.9.0",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-expo": "^56.0.5",
    "lint-staged": "^15.5.2",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.5",
    "source-map-explorer": "^2.5.3",
    "terser": "^5.31.0",
    "tsc-files": "^1.1.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "private": true
}
