STAGED_TEST_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)(__tests__/|tests/)|\.(test|spec)\.[^/]+$' || true)"

if [ -n "$STAGED_TEST_FILES" ]; then
	echo "[pre-commit] Unstaging test files by policy:"
	printf '%s\n' "$STAGED_TEST_FILES"
	printf '%s\n' "$STAGED_TEST_FILES" | while IFS= read -r file; do
		[ -n "$file" ] || continue
		git restore --staged -- "$file" 2>/dev/null || git reset -q HEAD -- "$file"
	done
fi

npm run secrets:scan
npx lint-staged
