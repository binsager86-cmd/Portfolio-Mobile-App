# Copy this file to .env and fill in your values
# DO NOT commit .env files with real secrets
# See GOOGLE_AUTH_SETUP.md for full instructions

# ── Backend API URL ──────────────────────────────────────────────────
# Global override (optional): applies to all platforms
# EXPO_PUBLIC_API_URL=https://backend-api-app-hfc2n.ondigitalocean.app

# Platform-specific overrides (recommended for local dev)
# Web local backend:
EXPO_PUBLIC_API_URL_WEB=http://127.0.0.1:8004

# Android emulator backend:
# EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:8004

# Android physical device backend (replace with your LAN IP):
# EXPO_PUBLIC_API_URL_ANDROID=http://192.168.1.5:8004

# iOS simulator/backend override (optional)
# EXPO_PUBLIC_API_URL_IOS=http://127.0.0.1:8004

# ── Google OAuth ─────────────────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials

# Web client (required for web + backend token verification)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# iOS client (required for native iOS builds)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Android client (required for native Android builds)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ── EODHD (Whale Tracker) ───────────────────────────────────────────
# Token used by Whale Tracker analytics endpoint calls
# EXPO_PUBLIC_EODHD_API_TOKEN=your-eodhd-api-token

EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id-here
